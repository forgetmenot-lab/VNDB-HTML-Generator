{
  "name": "vndb-html-generator",
  "version": "1.0.0",
  "description": "VNDB → HTML Generator",
  "author": "YourName",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.vndb.htmlgenerator",
    "productName": "VNDB HTML Generator",
    "files": [
      "main.js",
      "server.js",
      "vndb_tool.html",
      "icon.ico",
      "node_modules/**"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "icon.ico"
    },
    "portable": {
      "artifactName": "VNDB-HTML-Generator.exe"
    }
  }
}
